# Client Firebase config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Client Supabase config
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server AI config
GOOGLE_API_KEY=

# Server Firebase Admin config (required for durable competitions backend)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep escaped newlines (\n) if your provider does not allow multiline secrets
FIREBASE_PRIVATE_KEY=

# Server Supabase config (keep this secret, never expose it to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Optional secret for scheduled verification endpoint authentication
VERIFICATION_CRON_SECRET=
